# misc.
alias q='exit'
alias c='clear'
alias fk='fuck'

# cd
alias ~='cd ~'
alias ..='cd ../'
alias ...='cd ../../'
alias ....='cd ../../../'
alias .....='cd ../../../../'

# ls (eza is the maintained fork of exa)
if command -v eza &> /dev/null
then
    alias ls='eza'
    alias la='eza -aF'
    alias ll='eza -lF'
    alias l='eza -laF --git'
else
    alias ls='ls -GF'
    alias la='ls -aGF'
    alias ll='ls -lGF'
    alias l='ls -laghFG'
fi

# fzf history search
fh() {
  eval $( ([ -n "$ZSH_NAME" ] && fc -l 1 || history) | fzf +s --tac | sed 's/ *[0-9]* *//')
}

# for git aliases
function current_branch() {
  ref=$(git symbolic-ref HEAD 2> /dev/null) || \
  ref=$(git rev-parse --short HEAD 2> /dev/null) || return
  echo ${ref#refs/heads/}
}

# git status
alias gs='git status'

# git add
alias ga='git add'
alias ga.='git add .'

# git commit
alias gc='git commit -v'
alias gca='git commit -va'
alias gcam='git commit -vam'
alias gcm='git commit -vm'
alias gc!='git commit -v --amend'

# git push
alias gpush='git push origin $(current_branch)'

# git pull
alias gpull='git pull origin $(current_branch)'

# git branch
alias gb='git branch'
alias gba='git branch -a'
alias gbc='git branch --merged | grep -vE "(^\*|master|develop)" | xargs -r git branch -d'
alias gbd='git branch -d'
alias gbD='git branch -D'

# git checkout
alias gco='git checkout'
alias gcob='git checkout -b'

# git diff
alias gd='git diff --color-words=. --ignore-all-space'
alias gdc='git diff --cached'

# git fetch
alias gf='git fetch'

# git log
alias gl="git log --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias gll="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --stat"

# git reset
alias grh='git reset HEAD'
alias grhh='git reset HEAD --hard'

# git stash
alias gst='git stash'
alias gsts='git stash show --text'
alias gsta='git stash apply'
alias gstp='git stash pop'
alias gstd='git stash drop'

# grep (use ripgrep for speed)
if command -v rg &> /dev/null
then
    alias grep='rg'
    alias grepi='rg -i'
    alias grepl='rg -l'
fi

# speed test stuff
alias myip='curl https://ipinfo.io/json'
alias speedtest='curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python3 -'
